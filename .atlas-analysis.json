  "keyFeatures": [
    "HTTP 402 payment protocol (x402) for paywalled APIs",
    "Agent-to-agent autonomous payments with smart wallets",
    "Crossmint smart wallet integration (no private key management)",
    "Cloudflare Durable Objects for stateful agent architecture",
    "EIP-712 typed data signatures and ERC-6492 pre-deployment support",
    "Multiple blockchain support (Base, Solana)",
    "Production-ready MCP (Model Context Protocol) integration",
    "Express, Hono, and Next.js middleware for payment validation"
  ],
